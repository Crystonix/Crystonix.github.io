---
const navigation = [
  { href: '/', label: 'Home' },
  { href: '/projects/', label: 'Projects' },
  { href: '/about/', label: 'About' },
  { href: '/resume/', label: 'Resume' },
];
---

<header class="site-header">
  <div class="site-header__inner">
    <a class="site-logo" href="/" aria-label="Crystonix home">
      <span class="site-logo__mark" aria-hidden="true">C</span>
      <span>Crystonix</span>
    </a>

    <nav class="site-nav" aria-label="Primary navigation">
      {navigation.map((item) => <a href={item.href}>{item.label}</a>)}
      <a href="https://github.com/Crystonix" rel="noreferrer">GitHub</a>
    </nav>
  </div>
</header>
