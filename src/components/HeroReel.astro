---
import HeroReelTile from "./HeroReelTile.astro";

type MediaCover = {
  type: "image" | "video";
  src: string;
  alt?: string;
  position?: string;
  poster?: string;
};

interface ReelItem {
  title: string;
  label: string;
  href: string;
  cover: MediaCover;
}

interface Props {
  items: ReelItem[];
}

const { items } = Astro.props;
---

<aside class="hero-reel-shell" aria-label="Selected visual work preview">
  <div class="hero-reel">
    {items.map((item, index) => (
      <HeroReelTile
        title={item.title}
        label={item.label}
        href={item.href}
        cover={item.cover}
        featured={index === 0}
        loading={index === 0 ? "eager" : "lazy"}
      />
    ))}
  </div>
</aside>

<style>
  .hero-reel-shell {
    position: relative;
    isolation: isolate;
    min-height: clamp(22rem, 40vw, 32rem);
  }

  .hero-reel {
    display: grid;
    min-height: inherit;
    grid-template-columns: minmax(0, 1.55fr) minmax(11rem, 0.95fr);
    grid-template-rows: repeat(3, minmax(0, 1fr));
    gap: clamp(0.7rem, 1.2vw, 0.95rem);
  }

  .hero-reel :global(.hero-reel-tile--featured) {
    grid-column: 1 / 2;
    grid-row: 1 / 4;
  }

  .hero-reel :global(.hero-reel-tile:not(.hero-reel-tile--featured):nth-child(2)) {
    grid-column: 2 / 3;
    grid-row: 1 / 2;
  }

  .hero-reel :global(.hero-reel-tile:not(.hero-reel-tile--featured):nth-child(3)) {
    grid-column: 2 / 3;
    grid-row: 2 / 3;
  }

  .hero-reel :global(.hero-reel-tile:not(.hero-reel-tile--featured):nth-child(4)) {
    grid-column: 2 / 3;
    grid-row: 3 / 4;
  }

  @media (max-width: 960px) {
    .hero-reel-shell {
      min-height: clamp(24rem, 68vw, 34rem);
    }
  }

  @media (max-width: 620px) {
    .hero-reel {
      min-height: auto;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      grid-template-rows: none;
    }

    .hero-reel :global(.hero-reel-tile) {
      min-height: 9.5rem;
      grid-column: auto !important;
      grid-row: auto !important;
    }

    .hero-reel :global(.hero-reel-tile--featured) {
      min-height: 14rem;
      grid-column: span 2 !important;
    }
  }
</style>
