---
import HeroReelTile from './HeroReelTile.astro';

type MediaCover = {
  type: 'image' | 'video';
  src: string;
  alt?: string;
  position?: string;
  poster?: string;
};

type HeroReelAspect = 'wide' | 'landscape' | 'portrait' | 'square';
type HeroReelVariant = 'featured' | 'strip';

interface ReelItem {
  title: string;
  label: string;
  href: string;
  cover: MediaCover;
  aspect?: HeroReelAspect;
}

interface Props {
  items: ReelItem[];
  featuredAspect?: HeroReelAspect;
  supportingAspect?: HeroReelAspect;
  label?: string;
  variant?: HeroReelVariant;
}

const {
  items,
  featuredAspect = 'wide',
  supportingAspect = 'wide',
  label = 'Selected project previews',
  variant = 'featured',
} = Astro.props;
const [featuredItem, ...supportingItems] = items;
---

<aside
  class:list={['hero-reel-shell', `hero-reel-shell--${variant}`]}
  aria-label={label}
>
  <div class="hero-reel-stage">
    <div class:list={['hero-reel', `hero-reel--${variant}`]}>
      {
        variant === 'featured' && featuredItem && (
          <section class="hero-reel__featured" aria-label="Featured preview">
            <HeroReelTile
              title={featuredItem.title}
              label={featuredItem.label}
              href={featuredItem.href}
              cover={featuredItem.cover}
              featured
              aspect={featuredItem.aspect ?? featuredAspect}
              loading="eager"
            />
          </section>
        )
      }

      {
        variant === 'featured' && supportingItems.length > 0 && (
          <section
            class="hero-reel__supporting"
            aria-label="More project previews"
          >
            {supportingItems.map((item) => (
              <HeroReelTile
                title={item.title}
                label={item.label}
                href={item.href}
                cover={item.cover}
                aspect={item.aspect ?? supportingAspect}
                loading="lazy"
              />
            ))}
          </section>
        )
      }

      {
        variant === 'strip' && items.length > 0 && (
          <section class="hero-reel__strip" aria-label="Project previews">
            {items.map((item) => (
              <HeroReelTile
                title={item.title}
                label={item.label}
                href={item.href}
                cover={item.cover}
                aspect={item.aspect ?? supportingAspect}
                loading="lazy"
              />
            ))}
          </section>
        )
      }
    </div>
  </div>
</aside>

<style>
  .hero-reel-shell {
    position: relative;
    isolation: isolate;
  }

  .hero-reel-stage {
    position: relative;
    overflow: hidden;
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: clamp(1.35rem, 2.6vw, 2rem);
    background:
      radial-gradient(
        circle at 15% 0%,
        rgba(125, 211, 252, 0.16),
        transparent 34%
      ),
      radial-gradient(
        circle at 88% 14%,
        rgba(14, 165, 233, 0.12),
        transparent 36%
      ),
      rgba(8, 13, 24, 0.64);
    box-shadow: none;
    padding: clamp(0.65rem, 1.35vw, 1rem);
  }

  .hero-reel-stage::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(
      135deg,
      rgba(255, 255, 255, 0.08),
      transparent 34%,
      rgba(125, 211, 252, 0.06)
    );
    pointer-events: none;
  }

  .hero-reel {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: minmax(0, 1fr);
    gap: clamp(0.7rem, 1.2vw, 0.95rem);
  }

  .hero-reel__featured,
  .hero-reel__supporting,
  .hero-reel__strip {
    display: grid;
    min-width: 0;
  }

  .hero-reel__supporting,
  .hero-reel__strip {
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: clamp(0.7rem, 1.2vw, 0.95rem);
  }

  @media (max-width: 720px) {
    .hero-reel__supporting,
    .hero-reel__strip {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 520px) {
    .hero-reel-stage {
      padding: 0.55rem;
    }

    .hero-reel__supporting,
    .hero-reel__strip {
      grid-template-columns: 1fr;
    }
  }
</style>