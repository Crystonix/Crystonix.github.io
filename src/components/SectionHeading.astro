---
interface Props {
  label: string;
  title: string;
  description?: string;
}

const { label, title, description } = Astro.props;
---

<div class="section__header">
  <p class="section__label">{label}</p>
  <h2 class="section__title">{title}</h2>
  {description && <p class="section__description">{description}</p>}
</div>
