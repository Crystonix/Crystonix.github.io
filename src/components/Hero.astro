---
import HeroReel from "./HeroReel.astro";

type MediaCover = {
  type: "image" | "video";
  src: string;
  alt?: string;
  position?: string;
  poster?: string;
};

interface ReelItem {
  title: string;
  label: string;
  href: string;
  cover: MediaCover;
}

interface Props {
  eyebrow: string;
  title: string;
  lead: string;
  reelItems?: ReelItem[];
}

const { eyebrow, title, lead, reelItems = [] } = Astro.props;
---

<section
  class:list={["hero", reelItems.length > 0 && "hero--with-reel"]}
  aria-labelledby="hero-title"
>
  <div class="hero__content">
    <p class="eyebrow">{eyebrow}</p>
    <h1 id="hero-title">{title}</h1>
    <p class="hero__lead">{lead}</p>
    <div class="hero__actions">
      <a class="button button--primary" href="/projects/">View projects</a>
      <a
        class="button button--secondary"
        href="https://github.com/Crystonix"
        rel="noreferrer"
      >
        Open GitHub
      </a>
    </div>
  </div>

  {reelItems.length > 0 && <HeroReel items={reelItems} />}
</section>

<style>
  .hero {
    position: relative;
    display: grid;
    min-height: auto;
    align-items: center;
    padding: clamp(3rem, 7vw, 5.5rem) 0 clamp(2.5rem, 5vw, 4rem);
  }

  .hero--with-reel {
    grid-template-columns: minmax(0, 0.92fr) minmax(22rem, 1.08fr);
    gap: clamp(2rem, 5vw, 4.25rem);
  }

  .hero__content {
    position: relative;
    z-index: 2;
    max-width: 680px;
  }

  h1 {
    max-width: 13ch;
    margin: 0;
    font-size: clamp(3.4rem, 10vw, 7.4rem);
    line-height: 0.9;
    letter-spacing: -0.08em;
  }

  .hero__lead {
    max-width: 720px;
    margin: 1.35rem 0 0;
    color: var(--color-muted);
    font-size: clamp(1.1rem, 2vw, 1.35rem);
  }

  .hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.85rem;
    margin-top: 1.8rem;
  }

  @media (max-width: 960px) {
    .hero--with-reel {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 620px) {
    .hero {
      padding-top: clamp(2.5rem, 10vw, 3.5rem);
    }
  }
</style>
