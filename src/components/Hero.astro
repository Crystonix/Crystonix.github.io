---
import HeroReelTile from './HeroReelTile.astro';

type MediaCover = {
  type: 'image' | 'video';
  src: string;
  alt?: string;
  position?: string;
  poster?: string;
};

type HeroVisualAspect = 'wide' | 'landscape' | 'portrait' | 'square';

interface HeroVisualItem {
  title: string;
  label: string;
  href: string;
  cover: MediaCover;
  aspect?: HeroVisualAspect;
}

interface Props {
  eyebrow: string;
  title: string;
  lead: string;
  visualItem?: HeroVisualItem;
}

const { eyebrow, title, lead, visualItem } = Astro.props;
---

<section
  class:list={['hero', visualItem && 'hero--with-visual']}
  aria-labelledby="hero-title"
>
  <div class="hero__inner">
    <div class="hero__content">
      <p class="eyebrow">{eyebrow}</p>
      <h1 id="hero-title">{title}</h1>
      <p class="hero__lead">{lead}</p>
      <div class="hero__actions">
        <a class="button button--primary" href="/projects/">View projects</a>
        <a
          class="button button--secondary"
          href="https://github.com/Crystonix"
          rel="noreferrer"
        >
          Open GitHub
        </a>
      </div>
    </div>

    {
      visualItem && (
        <div class="hero__visual" aria-label="Featured project preview">
          <HeroReelTile
            title={visualItem.title}
            label={visualItem.label}
            href={visualItem.href}
            cover={visualItem.cover}
            featured
            aspect={visualItem.aspect ?? 'wide'}
            ambientGlow="strong"
            loading="eager"
          />
        </div>
      )
    }
  </div>
</section>

<style>
  .hero {
    position: relative;
    isolation: isolate;
    padding: clamp(3rem, 7vw, 5.75rem) 0 clamp(2.5rem, 5vw, 4rem);
  }

  .hero::before {
    content: '';
    position: absolute;
    inset: clamp(0.5rem, 2vw, 1rem) calc(50% - min(50vw, 42rem));
    z-index: -1;
    border-radius: clamp(1.75rem, 4vw, 3rem);
    background:
      radial-gradient(
        circle at 22% 18%,
        rgba(125, 211, 252, 0.12),
        transparent 34%
      ),
      radial-gradient(
        circle at 82% 16%,
        rgba(14, 165, 233, 0.1),
        transparent 30%
      ),
      linear-gradient(135deg, rgba(255, 255, 255, 0.045), transparent 48%);
    pointer-events: none;
  }

  .hero__inner {
    display: grid;
    align-items: center;
    gap: clamp(2rem, 5vw, 4.25rem);
  }

  .hero--with-visual .hero__inner {
    grid-template-columns: minmax(0, 0.9fr) minmax(24rem, 1.1fr);
  }

  .hero__content {
    position: relative;
    z-index: 2;
    max-width: 700px;
  }

  h1 {
    max-width: 13ch;
    margin: 0;
    font-size: clamp(3.4rem, 10vw, 7.4rem);
    line-height: 0.9;
    letter-spacing: -0.08em;
  }

  .hero__lead {
    max-width: 720px;
    margin: 1.35rem 0 0;
    color: var(--color-muted);
    font-size: clamp(1.1rem, 2vw, 1.35rem);
  }

  .hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.85rem;
    margin-top: 1.8rem;
  }

  .hero__visual {
    position: relative;
    z-index: 1;
    min-width: 0;
  }

  .hero__visual::before {
    content: '';
    position: absolute;
    inset: -1rem;
    z-index: -1;
    border-radius: clamp(1.5rem, 3vw, 2.4rem);
    background: rgba(8, 13, 24, 0.46);
    filter: blur(0.2px);
  }

  @media (max-width: 960px) {
    .hero--with-visual .hero__inner {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 620px) {
    .hero {
      padding-top: clamp(2.5rem, 10vw, 3.5rem);
    }
  }
</style>
