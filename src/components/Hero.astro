---
import MediaFrame from './MediaFrame.astro';

interface MediaCover {
  type: 'image' | 'video';
  src: string;
  alt?: string;
  position?: string;
  poster?: string;
}

interface ReelItem {
  title: string;
  label: string;
  href: string;
  cover: MediaCover;
}

interface Props {
  eyebrow: string;
  title: string;
  lead: string;
  reelItems?: ReelItem[];
}

const { eyebrow, title, lead, reelItems = [] } = Astro.props;
---

<section class:list={['hero', reelItems.length > 0 && 'hero--with-reel']} aria-labelledby="hero-title">
  <div class="hero__content">
    <p class="eyebrow">{eyebrow}</p>
    <h1 id="hero-title">{title}</h1>
    <p class="hero__lead">{lead}</p>
    <div class="hero__actions">
      <a class="button button--primary" href="/projects/">View projects</a>
      <a class="button button--secondary" href="https://github.com/Crystonix" rel="noreferrer">Open GitHub</a>
    </div>
  </div>

  {reelItems.length > 0 && (
    <aside class="hero-reel-shell" aria-label="Selected visual work preview">
      <div class="hero-reel">
        {reelItems.map((item, index) => (
          <a class={`hero-reel__item hero-reel__item--${index + 1}`} href={item.href}>
            <MediaFrame
              media={item.cover}
              variant="hero"
              decorative
              loading={index === 0 ? 'eager' : 'lazy'}
              autoplay={item.cover.type === 'video'}
              controls={false}
              muted
              loop
            />
            <div class="hero-reel__scrim" aria-hidden="true"></div>
            <div class="hero-reel__label">
              <span>{item.label}</span>
              <strong>{item.title}</strong>
            </div>
          </a>
        ))}
      </div>
    </aside>
  )}
</section>

<style>
  .hero {
    position: relative;
    display: grid;
    min-height: calc(100vh - 5rem);
    align-items: center;
    padding: clamp(4rem, 10vw, 8rem) 0 clamp(3rem, 8vw, 6rem);
  }

  .hero--with-reel {
    grid-template-columns: minmax(0, 0.88fr) minmax(20rem, 1.12fr);
    gap: clamp(2.25rem, 6vw, 5rem);
  }

  .hero__content {
    position: relative;
    z-index: 2;
    max-width: 680px;
  }

  h1 {
    max-width: 13ch;
    margin: 0;
    font-size: clamp(3.4rem, 10vw, 7.4rem);
    line-height: 0.9;
    letter-spacing: -0.08em;
  }

  .hero__lead {
    max-width: 720px;
    margin: 1.5rem 0 0;
    color: var(--color-muted);
    font-size: clamp(1.15rem, 2vw, 1.4rem);
  }

  .hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.9rem;
    margin-top: 2rem;
  }

  .hero-reel-shell {
    position: relative;
    isolation: isolate;
    min-height: clamp(28rem, 52vw, 37rem);
  }

  .hero-reel {
    display: grid;
    min-height: inherit;
    grid-template-columns: repeat(6, minmax(0, 1fr));
    grid-template-rows: repeat(6, minmax(0, 1fr));
    gap: clamp(0.65rem, 1.4vw, 1rem);
    transform: rotate(-1.5deg);
  }

  .hero-reel__item {
    position: relative;
    display: block;
    overflow: hidden;
    min-height: 8rem;
    border: 1px solid rgba(255, 255, 255, 0.16);
    border-radius: clamp(1.1rem, 2.2vw, 1.9rem);
    background: rgba(255, 255, 255, 0.05);
    box-shadow: 0 28px 90px rgba(0, 0, 0, 0.42);
  }

  .hero-reel__item--1 {
    grid-column: 1 / 5;
    grid-row: 1 / 4;
  }

  .hero-reel__item--2 {
    grid-column: 3 / 7;
    grid-row: 3 / 7;
  }

  .hero-reel__item--3 {
    grid-column: 1 / 4;
    grid-row: 4 / 7;
  }

  .hero-reel__item--4 {
    grid-column: 5 / 7;
    grid-row: 1 / 3;
  }

  .hero-reel__scrim {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(180deg, rgba(3, 5, 10, 0.08) 0%, rgba(3, 5, 10, 0.72) 100%),
      radial-gradient(circle at 0% 100%, rgba(3, 5, 10, 0.84), transparent 62%);
    pointer-events: none;
  }

  .hero-reel__label {
    position: absolute;
    right: clamp(0.65rem, 1.6vw, 0.95rem);
    bottom: clamp(0.65rem, 1.6vw, 0.95rem);
    left: clamp(0.65rem, 1.6vw, 0.95rem);
    display: grid;
    width: fit-content;
    max-width: calc(100% - 1.3rem);
    gap: 0.16rem;
    border: 1px solid rgba(255, 255, 255, 0.16);
    border-radius: 1rem;
    background: rgba(3, 5, 10, 0.64);
    box-shadow: 0 16px 50px rgba(0, 0, 0, 0.34);
    padding: 0.62rem 0.7rem;
    backdrop-filter: blur(18px);
  }

  .hero-reel__label span {
    color: var(--color-accent);
    font-size: 0.66rem;
    font-weight: 850;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .hero-reel__label strong {
    color: var(--color-text);
    font-size: clamp(0.92rem, 1.5vw, 1.08rem);
    line-height: 1.05;
    text-wrap: balance;
  }

  @media (max-width: 960px) {
    .hero--with-reel {
      min-height: auto;
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 620px) {
    .hero-reel {
      min-height: auto;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      grid-template-rows: none;
      transform: none;
    }

    .hero-reel__item {
      min-height: 10rem;
      grid-column: auto;
      grid-row: auto;
    }

    .hero-reel__item--1,
    .hero-reel__item--2 {
      grid-column: span 2;
    }
  }
</style>
