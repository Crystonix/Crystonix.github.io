---
interface MediaCover {
  type: 'image' | 'video' | 'youtube';
  src: string;
  alt?: string;
}

interface Props {
  title: string;
  description: string;
  href?: string;
  tags?: string[];
  category?: string;
  status?: string;
  cover?: MediaCover;
}

const { title, description, href, tags = [], category, status, cover } = Astro.props;
---

<article class="project-card">
  {cover && (
    <div class="project-card__cover" aria-hidden={cover.alt ? undefined : 'true'}>
      {cover.type === 'video' ? (
        <video src={cover.src} autoplay muted loop playsinline preload="metadata"></video>
      ) : (
        <img src={cover.src} alt={cover.alt ?? ''} loading="lazy" />
      )}
    </div>
  )}

  {(category || status) && (
    <div class="project-card__topline">
      {category && <span>{category}</span>}
      {status && <span>{status}</span>}
    </div>
  )}

  <h3>{title}</h3>
  <p>{description}</p>

  {tags.length > 0 && (
    <div class="project-card__meta" aria-label="Project tags">
      {tags.map((tag) => <span class="badge">{tag}</span>)}
    </div>
  )}

  {href && <a class="project-card__link" href={href}>View project →</a>}
</article>
