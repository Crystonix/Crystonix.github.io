---
import MediaFrame from './MediaFrame.astro';

type MediaCover = {
  type: 'image' | 'video';
  src: string;
  alt?: string;
  position?: string;
  poster?: string;
};

type HeroReelAspect = 'wide' | 'landscape' | 'portrait' | 'square';

interface Props {
  title: string;
  label: string;
  href: string;
  cover: MediaCover;
  featured?: boolean;
  loading?: 'eager' | 'lazy';
  aspect?: HeroReelAspect;
}

const {
  title,
  label,
  href,
  cover,
  featured = false,
  loading = 'lazy',
  aspect = 'wide',
} = Astro.props;
---

<a
  class:list={[
    'hero-reel-tile',
    `hero-reel-tile--${aspect}`,
    featured && 'hero-reel-tile--featured',
  ]}
  href={href}
>
  <MediaFrame
    media={cover}
    variant="hero"
    decorative
    loading={loading}
    autoplay={cover.type === 'video'}
    controls={false}
    muted
    loop
  />
  <div class="hero-reel-tile__scrim" aria-hidden="true"></div>
  <div class="hero-reel-tile__label">
    <span>{label}</span>
    <strong>{title}</strong>
  </div>
</a>

<style>
  .hero-reel-tile {
    position: relative;
    display: block;
    overflow: hidden;
    min-height: 0;
    aspect-ratio: var(--hero-reel-tile-aspect, 16 / 9);
    border: 1px solid rgba(255, 255, 255, 0.14);
    border-radius: clamp(1rem, 1.8vw, 1.45rem);
    background: rgba(255, 255, 255, 0.05);
    box-shadow: 0 24px 70px rgba(0, 0, 0, 0.34);
  }

  .hero-reel-tile--wide {
    --hero-reel-tile-aspect: 16 / 9;
  }

  .hero-reel-tile--landscape {
    --hero-reel-tile-aspect: 4 / 3;
  }

  .hero-reel-tile--portrait {
    --hero-reel-tile-aspect: 3 / 4;
  }

  .hero-reel-tile--square {
    --hero-reel-tile-aspect: 1 / 1;
  }

  .hero-reel-tile:hover,
  .hero-reel-tile:focus-visible {
    color: var(--color-text);
    border-color: rgba(125, 211, 252, 0.42);
  }

  .hero-reel-tile__scrim {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      180deg,
      transparent 58%,
      rgba(3, 5, 10, 0.3) 100%
    );
    pointer-events: none;
  }

  .hero-reel-tile__label {
    position: absolute;
    right: clamp(0.55rem, 1.2vw, 0.8rem);
    bottom: clamp(0.55rem, 1.2vw, 0.8rem);
    left: clamp(0.55rem, 1.2vw, 0.8rem);
    display: grid;
    width: fit-content;
    max-width: calc(100% - 1.1rem);
    gap: 0.24rem;
    border: 1px solid rgba(255, 255, 255, 0.16);
    border-radius: clamp(0.7rem, 1.4vw, 1rem);
    background: rgba(3, 5, 10, 0.68);
    padding: clamp(0.46rem, 1vw, 0.66rem);
    box-shadow: 0 18px 44px rgba(0, 0, 0, 0.32);
    backdrop-filter: blur(16px);
  }

  .hero-reel-tile__label span {
    width: fit-content;
    border: 1px solid rgba(125, 211, 252, 0.28);
    border-radius: 999px;
    background: rgba(8, 47, 73, 0.78);
    color: var(--color-accent);
    font-size: 0.6rem;
    font-weight: 850;
    letter-spacing: 0.13em;
    padding: 0.24rem 0.48rem;
    text-transform: uppercase;
  }

  .hero-reel-tile__label strong {
    width: fit-content;
    max-width: 100%;
    border-radius: 0.55rem;
    background: rgba(255, 255, 255, 0.07);
    color: var(--color-text);
    font-size: clamp(0.84rem, 1.2vw, 0.98rem);
    line-height: 1.08;
    padding: 0.22rem 0.36rem;
    text-wrap: balance;
  }

  .hero-reel-tile--featured .hero-reel-tile__label strong {
    font-size: clamp(1.05rem, 1.8vw, 1.35rem);
  }

  @media (max-width: 620px) {
    .hero-reel-tile__label {
      width: auto;
    }
  }
</style>
