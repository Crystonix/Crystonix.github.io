---
import MediaFrame from './MediaFrame.astro';

type MediaCover = {
  type: 'image' | 'video';
  src: string;
  alt?: string;
  position?: string;
  poster?: string;
};

type HeroReelAspect = 'wide' | 'landscape' | 'portrait' | 'square';
type AmbientGlow = 'none' | 'soft' | 'strong';

interface Props {
  title: string;
  label: string;
  href: string;
  cover: MediaCover;
  featured?: boolean;
  loading?: 'eager' | 'lazy';
  aspect?: HeroReelAspect;
  ambientGlow?: AmbientGlow;
}

const {
  title,
  label,
  href,
  cover,
  featured = false,
  loading = 'lazy',
  aspect = 'wide',
  ambientGlow = 'soft',
} = Astro.props;

const glowSrc = cover.type === 'image' ? cover.src : cover.poster;
const hasAmbientGlow = ambientGlow !== 'none' && Boolean(glowSrc);
---

<a
  class:list={[
    'hero-reel-tile',
    `hero-reel-tile--${aspect}`,
    `hero-reel-tile--glow-${ambientGlow}`,
    featured && 'hero-reel-tile--featured',
  ]}
  data-ambient-glow={hasAmbientGlow ? ambientGlow : undefined}
  href={href}
>
  <div class="hero-reel-tile__media-shell">
    {
      hasAmbientGlow && glowSrc && (
        <img
          class="hero-reel-tile__ambient"
          src={glowSrc}
          alt=""
          aria-hidden="true"
          loading={loading}
          style={{ objectPosition: cover.position ?? 'center' }}
        />
      )
    }

    <div class="hero-reel-tile__media">
      <MediaFrame
        media={cover}
        variant="hero"
        decorative
        loading={loading}
        autoplay={cover.type === 'video'}
        controls={false}
        muted
        loop
      />
    </div>
  </div>

  <div class="hero-reel-tile__meta">
    <span>{label}</span>
    <strong>{title}</strong>
  </div>
</a>

<style>
  .hero-reel-tile {
    --hero-reel-tile-glow-opacity: 0;
    --hero-reel-tile-glow-scale: 1.04;
    --hero-reel-tile-glow-blur: 1.25rem;

    position: relative;
    display: grid;
    min-width: 0;
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: clamp(1rem, 1.8vw, 1.45rem);
    background: rgba(8, 13, 24, 0.74);
    box-shadow: 0 24px 70px rgba(0, 0, 0, 0.26);
    transition:
      border-color 180ms ease,
      background 180ms ease,
      transform 180ms ease;
  }

  .hero-reel-tile[data-ambient-glow='soft'] {
    --hero-reel-tile-glow-opacity: 0.36;
    --hero-reel-tile-glow-scale: 1.055;
    --hero-reel-tile-glow-blur: 1.35rem;
  }

  .hero-reel-tile[data-ambient-glow='strong'] {
    --hero-reel-tile-glow-opacity: 0.58;
    --hero-reel-tile-glow-scale: 1.075;
    --hero-reel-tile-glow-blur: 1.75rem;
  }

  .hero-reel-tile:hover,
  .hero-reel-tile:focus-visible {
    color: var(--color-text);
    border-color: rgba(125, 211, 252, 0.42);
    background: rgba(10, 18, 32, 0.86);
    transform: translateY(-2px);
  }

  .hero-reel-tile:hover[data-ambient-glow],
  .hero-reel-tile:focus-visible[data-ambient-glow] {
    --hero-reel-tile-glow-opacity: 0.66;
  }

  .hero-reel-tile--glow-strong:hover,
  .hero-reel-tile--glow-strong:focus-visible {
    --hero-reel-tile-glow-opacity: 0.78;
  }

  .hero-reel-tile__media-shell {
    position: relative;
    isolation: isolate;
    min-width: 0;
  }

  .hero-reel-tile__ambient {
    position: absolute;
    inset: -0.55rem;
    z-index: -1;
    width: calc(100% + 1.1rem);
    height: calc(100% + 1.1rem);
    border-radius: inherit;
    filter: blur(var(--hero-reel-tile-glow-blur)) saturate(1.35) contrast(1.06);
    opacity: var(--hero-reel-tile-glow-opacity);
    pointer-events: none;
    transform: scale(var(--hero-reel-tile-glow-scale));
    transition:
      opacity 180ms ease,
      transform 180ms ease;
  }

  .hero-reel-tile__media {
    position: relative;
    overflow: hidden;
    aspect-ratio: var(--hero-reel-tile-aspect, 16 / 9);
    border-radius: inherit;
    border-bottom-right-radius: 0;
    border-bottom-left-radius: 0;
    background: rgba(255, 255, 255, 0.05);
  }

  .hero-reel-tile--wide {
    --hero-reel-tile-aspect: 16 / 9;
  }

  .hero-reel-tile--landscape {
    --hero-reel-tile-aspect: 4 / 3;
  }

  .hero-reel-tile--portrait {
    --hero-reel-tile-aspect: 3 / 4;
  }

  .hero-reel-tile--square {
    --hero-reel-tile-aspect: 1 / 1;
  }

  .hero-reel-tile__meta {
    display: grid;
    gap: 0.42rem;
    padding: clamp(0.7rem, 1.35vw, 0.95rem);
    border-bottom-right-radius: inherit;
    border-bottom-left-radius: inherit;
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.045), transparent),
      rgba(3, 5, 10, 0.52);
  }

  .hero-reel-tile__meta span {
    width: fit-content;
    border: 1px solid rgba(125, 211, 252, 0.24);
    border-radius: 999px;
    background: rgba(8, 47, 73, 0.66);
    color: var(--color-accent);
    font-size: 0.6rem;
    font-weight: 850;
    letter-spacing: 0.13em;
    padding: 0.24rem 0.48rem;
    text-transform: uppercase;
  }

  .hero-reel-tile__meta strong {
    color: var(--color-text);
    font-size: clamp(0.9rem, 1.2vw, 1rem);
    line-height: 1.08;
    text-wrap: balance;
  }

  .hero-reel-tile--featured .hero-reel-tile__meta {
    grid-template-columns: auto minmax(0, 1fr);
    align-items: center;
  }

  .hero-reel-tile--featured .hero-reel-tile__meta strong {
    font-size: clamp(1.05rem, 1.8vw, 1.35rem);
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-reel-tile,
    .hero-reel-tile__ambient {
      transition: none;
    }

    .hero-reel-tile:hover,
    .hero-reel-tile:focus-visible {
      transform: none;
    }
  }

  @media (max-width: 620px) {
    .hero-reel-tile--featured .hero-reel-tile__meta {
      grid-template-columns: 1fr;
      align-items: start;
    }
  }
</style>