---
import BaseLayout from '../layouts/BaseLayout.astro';

const workingStyle = [
  'Build from a clean, understandable foundation.',
  'Prefer maintainable architecture over short-term patches.',
  'Keep deployment and project structure easy to audit.',
  'Turn meaningful work into clear documentation and case studies.',
];
---

<BaseLayout
  title="About | Crystonix"
  description="About page for the Crystonix portfolio."
>
  <header class="page-header">
    <p class="eyebrow">About</p>
    <h1 class="page-title">A practical engineering portfolio.</h1>
    <p class="page-lead">
      This site is the public home for Crystonix projects, technical notes, and
      engineering decisions.
    </p>
  </header>

  <section class="section split" aria-labelledby="about-focus-title">
    <div>
      <p class="section__label">Focus</p>
      <h2 id="about-focus-title" class="section__title">
        Document the work clearly.
      </h2>
    </div>
    <div class="stack">
      <p class="section__description">
        The portfolio is structured to grow from a simple homepage into a set of
        durable case studies. Each project can be expanded with context,
        architecture, trade-offs, implementation notes, and links.
      </p>
      <ul class="list">
        {workingStyle.map((item) => <li>{item}</li>)}
      </ul>
    </div>
  </section>

  <section class="section card" aria-labelledby="about-next-title">
    <p class="section__label">Next content pass</p>
    <h2 id="about-next-title" class="section__title">
      Add personal details only when they are accurate.
    </h2>
    <p class="section__description">
      The next version should replace this neutral copy with your actual
      background, technical stack, strongest projects, and preferred contact
      path.
    </p>
  </section>
</BaseLayout>
