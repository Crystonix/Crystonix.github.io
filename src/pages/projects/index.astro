---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import ProjectCard from '../../components/ProjectCard.astro';
import SectionHeading from '../../components/SectionHeading.astro';

const projects = (await getCollection('projects')).sort((a, b) => a.data.order - b.data.order);
const featuredProjects = projects.filter((project) => project.data.featured);
const categories = ['Web Projects', 'Game Systems', 'Visual Work'];
const groupedProjects = categories
  .map((category) => ({
    category,
    projects: projects.filter((project) => project.data.category === category),
  }))
  .filter((group) => group.projects.length > 0);
---

<BaseLayout
  title="Projects | Crystonix"
  description="A collection of web projects, game systems, visual experiments, animation work, and older project pieces by Crystonix."
>
  <header class="page-header">
    <p class="eyebrow">Projects</p>
    <h1 class="page-title">Projects, experiments, and visual work.</h1>
    <p class="page-lead">
      A collection of things I’ve built, tested, designed, animated, or kept developing over time.
    </p>
  </header>

  <section class="section" aria-labelledby="featured-index-title">
    <SectionHeading
      label="Featured"
      title="A few good places to start."
      description="These pieces show the range of the portfolio: web work, game systems, visual experiments, and animation."
    />
    <div class="card-grid">
      {featuredProjects.map((project) => (
        <ProjectCard
          title={project.data.title}
          description={project.data.description}
          href={`/projects/${project.id}/`}
          tags={project.data.tags}
          category={project.data.category}
          status={project.data.status}
        />
      ))}
    </div>
  </section>

  <section class="section" aria-labelledby="all-projects-title">
    <SectionHeading
      label="All projects"
      title="Browse by area."
      description="Web, game, and visual pieces are grouped separately so each side of the work has room to breathe."
    />

    <div class="project-groups">
      {groupedProjects.map((group) => (
        <section class="project-group" aria-labelledby={`${group.category.toLowerCase().replaceAll(' ', '-')}-title`}>
          <h2 id={`${group.category.toLowerCase().replaceAll(' ', '-')}-title`}>{group.category}</h2>
          <div class="card-grid">
            {group.projects.map((project) => (
              <ProjectCard
                title={project.data.title}
                description={project.data.description}
                href={`/projects/${project.id}/`}
                tags={project.data.tags}
                category={project.data.category}
                status={project.data.status}
              />
            ))}
          </div>
        </section>
      ))}
    </div>
  </section>
</BaseLayout>
