---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import ProjectCard from '../../components/ProjectCard.astro';
import SectionHeading from '../../components/SectionHeading.astro';

const projects = (await getCollection('projects')).sort((a, b) => a.data.order - b.data.order);
const featuredProjects = projects.filter((project) => project.data.featured);
const categories = ['Web applications', 'Game development', 'Tooling', 'Graphics and creative tech'];
const groupedProjects = categories
  .map((category) => ({
    category,
    projects: projects.filter((project) => project.data.category === category),
  }))
  .filter((group) => group.projects.length > 0);
---

<BaseLayout
  title="Projects | Crystonix"
  description="Curated project index for Crystonix: web applications, Godot systems, tooling, and creative technology work."
>
  <header class="page-header">
    <p class="eyebrow">Projects</p>
    <h1 class="page-title">Curated technical work.</h1>
    <p class="page-lead">
      A selected project index built from typed Markdown entries. Each project has a dedicated page for context, technical focus, and links.
    </p>
  </header>

  <section class="section" aria-labelledby="featured-index-title">
    <SectionHeading
      label="Featured"
      title="The strongest portfolio candidates."
      description="These are the projects currently suitable for the homepage because they have the clearest technical story or product architecture."
    />
    <div class="card-grid">
      {featuredProjects.map((project) => (
        <ProjectCard
          title={project.data.title}
          description={project.data.description}
          href={`/projects/${project.id}/`}
          tags={project.data.tags}
          category={project.data.category}
          status={project.data.status}
        />
      ))}
    </div>
  </section>

  <section class="section" aria-labelledby="all-projects-title">
    <SectionHeading
      label="Index"
      title="All displayed projects."
      description="Secondary projects are included when they add useful context, but the homepage remains intentionally selective."
    />

    <div class="project-groups">
      {groupedProjects.map((group) => (
        <section class="project-group" aria-labelledby={`${group.category.toLowerCase().replaceAll(' ', '-')}-title`}>
          <h2 id={`${group.category.toLowerCase().replaceAll(' ', '-')}-title`}>{group.category}</h2>
          <div class="card-grid">
            {group.projects.map((project) => (
              <ProjectCard
                title={project.data.title}
                description={project.data.description}
                href={`/projects/${project.id}/`}
                tags={project.data.tags}
                category={project.data.category}
                status={project.data.status}
              />
            ))}
          </div>
        </section>
      ))}
    </div>
  </section>
</BaseLayout>
