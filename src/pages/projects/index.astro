---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import ProjectCard from '../../components/ProjectCard.astro';
import SectionHeading from '../../components/SectionHeading.astro';

const projects = (await getCollection('projects')).sort((a, b) => a.data.order - b.data.order);
const featuredProjects = projects.filter((project) => project.data.featured);
const categories = ['Web products', 'Game systems', 'Visual work'];
const groupedProjects = categories
  .map((category) => ({
    category,
    projects: projects.filter((project) => project.data.category === category),
  }))
  .filter((group) => group.projects.length > 0);
---

<BaseLayout
  title="Projects | Crystonix"
  description="Selected projects by Crystonix: web products, Godot systems, procedural generation, game art, Blender animation, and browser-based visual work."
>
  <header class="page-header">
    <p class="eyebrow">Projects</p>
    <h1 class="page-title">Selected work.</h1>
    <p class="page-lead">
      A curated index of web products, game systems, visual scenes, game-art work, and animation projects.
    </p>
  </header>

  <section class="section" aria-labelledby="featured-index-title">
    <SectionHeading
      label="Featured"
      title="The strongest pieces to start with."
      description="These projects give the clearest first impression across product work, game systems, and visual presentation."
    />
    <div class="card-grid">
      {featuredProjects.map((project) => (
        <ProjectCard
          title={project.data.title}
          description={project.data.description}
          href={`/projects/${project.id}/`}
          tags={project.data.tags}
          category={project.data.category}
          status={project.data.status}
        />
      ))}
    </div>
  </section>

  <section class="section" aria-labelledby="all-projects-title">
    <SectionHeading
      label="Index"
      title="Work grouped by presentation area."
      description="The index keeps web, game, and visual work separate so the portfolio does not read like one long software-only list."
    />

    <div class="project-groups">
      {groupedProjects.map((group) => (
        <section class="project-group" aria-labelledby={`${group.category.toLowerCase().replaceAll(' ', '-')}-title`}>
          <h2 id={`${group.category.toLowerCase().replaceAll(' ', '-')}-title`}>{group.category}</h2>
          <div class="card-grid">
            {group.projects.map((project) => (
              <ProjectCard
                title={project.data.title}
                description={project.data.description}
                href={`/projects/${project.id}/`}
                tags={project.data.tags}
                category={project.data.category}
                status={project.data.status}
              />
            ))}
          </div>
        </section>
      ))}
    </div>
  </section>
</BaseLayout>
