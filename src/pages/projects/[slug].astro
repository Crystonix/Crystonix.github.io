---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import MediaFrame from '../../components/MediaFrame.astro';

export async function getStaticPaths() {
  const projects = await getCollection('projects');

  return projects.map((project) => ({
    params: { slug: project.id },
    props: { project },
  }));
}

const { project } = Astro.props;
const { Content } = await render(project);
const {
  title,
  description,
  category,
  status,
  tags,
  links,
  cover,
  media,
  highlights,
} = project.data;
const mediaItems = media.length > 0 ? media : cover ? [cover] : [];
const notes = highlights
  .map((highlight) =>
    typeof highlight === 'string' ? { text: highlight } : highlight,
  )
  .filter((highlight) => highlight.text.trim().length > 0);
---

<BaseLayout title={`${title} | Crystonix`} description={description}>
  <article class="project-detail">
    <header class="page-header project-detail__header">
      <p class="eyebrow">{category} · {status}</p>
      <h1 class="page-title">{title}</h1>
      <p class="page-lead">{description}</p>

      {
        (links.repo || links.demo) && (
          <div class="actions">
            {links.repo && (
              <a
                class="button button--primary"
                href={links.repo}
                rel="noreferrer"
              >
                View repository
              </a>
            )}
            {links.demo && (
              <a
                class="button button--secondary"
                href={links.demo}
                rel="noreferrer"
              >
                Open demo
              </a>
            )}
          </div>
        )
      }
    </header>

    {
      mediaItems.length > 0 && (
        <section class="project-media" aria-label="Project media">
          {mediaItems.map((item) => (
            <MediaFrame
              media={
                item.type === 'youtube' && !item.title
                  ? { ...item, title }
                  : item
              }
              variant="gallery"
              caption={item.title}
              loading="lazy"
              controls
            />
          ))}
        </section>
      )
    }

    <div class="project-detail__layout">
      <div class="project-detail__content prose">
        <Content />
      </div>

      <aside class="project-detail__aside card" aria-label="Project summary">
        <h2>At a glance</h2>

        <div class="project-detail__meta-list">
          <div>
            <span>Area</span>
            <strong>{category}</strong>
          </div>
          <div>
            <span>Type</span>
            <strong>{status}</strong>
          </div>
        </div>

        {
          tags.length > 0 && (
            <div>
              <h3>Tools</h3>
              <div class="tag-list" aria-label="Project tags">
                {tags.map((tag) => (
                  <span class="badge">{tag}</span>
                ))}
              </div>
            </div>
          )
        }

        {
          notes.length > 0 && (
            <div>
              <h3>Notes</h3>
              <ul class="list">
                {notes.map((note) => (
                  <li>
                    {note.title && <strong>{note.title}: </strong>}
                    {note.text}
                  </li>
                ))}
              </ul>
            </div>
          )
        }
      </aside>
    </div>
  </article>
</BaseLayout>

<style>
  .project-detail__header .page-title {
    max-width: 14ch;
  }

  .project-media {
    display: grid;
    gap: 1rem;
    margin: 0 0 clamp(2rem, 5vw, 3.5rem);
  }

  .project-detail__layout {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(18rem, 22rem);
    gap: clamp(1.5rem, 5vw, 3rem);
    align-items: start;
  }

  .project-detail__content {
    min-width: 0;
  }

  .project-detail__aside {
    position: sticky;
    top: 6rem;
    display: grid;
    gap: 1.3rem;
  }

  .project-detail__aside h2,
  .project-detail__aside h3 {
    margin: 0;
  }

  .project-detail__meta-list {
    display: grid;
    gap: 0.85rem;
  }

  .project-detail__meta-list div {
    display: grid;
    gap: 0.1rem;
    border-top: 1px solid var(--color-border);
    padding-top: 0.85rem;
  }

  .project-detail__meta-list span {
    color: var(--color-subtle);
    font-size: 0.78rem;
    font-weight: 800;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .project-detail__meta-list strong {
    color: var(--color-text);
  }

  .tag-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
  }

  @media (max-width: 820px) {
    .project-detail__layout {
      grid-template-columns: 1fr;
    }

    .project-detail__aside {
      position: static;
    }
  }
</style>
