---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const projects = await getCollection('projects');

  return projects.map((project) => ({
    params: { slug: project.id },
    props: { project },
  }));
}

const { project } = Astro.props;
const { Content } = await render(project);
const { title, description, category, status, tags, highlights, links, cover, media } = project.data;
const mediaItems = (media.length > 0 ? media : cover ? [cover] : []).map((item) => ({
  title: undefined,
  alt: undefined,
  poster: undefined,
  position: undefined,
  ...item,
}));

const stringifyValue = (value: unknown): string | null => {
  if (typeof value === 'string' && value.trim().length > 0) {
    return value;
  }

  if (typeof value === 'number' || typeof value === 'boolean') {
    return String(value);
  }

  if (Array.isArray(value)) {
    const parts = value.map((entry) => stringifyValue(entry)).filter(Boolean);
    return parts.length > 0 ? parts.join(' · ') : null;
  }

  if (value && typeof value === 'object') {
    const nested = Object.values(value)
      .map((entry) => stringifyValue(entry))
      .filter(Boolean);

    return nested.length > 0 ? nested.join(' · ') : null;
  }

  return null;
};

const getStringField = (value: Record<string, unknown>, keys: string[]) => {
  for (const key of keys) {
    const field = stringifyValue(value[key]);

    if (field) {
      return field;
    }
  }

  return null;
};

const formatHighlight = (highlight: unknown) => {
  if (typeof highlight === 'string') {
    return { title: null, text: highlight };
  }

  if (highlight && typeof highlight === 'object') {
    const value = highlight as Record<string, unknown>;
    const title = getStringField(value, ['title', 'label', 'name']);
    const text = getStringField(value, ['text', 'body', 'description', 'content', 'value']);

    if (text) {
      return { title, text };
    }

    const fallbackText = Object.entries(value)
      .filter(([key]) => !['title', 'label', 'name'].includes(key))
      .map(([, entry]) => stringifyValue(entry))
      .filter(Boolean)
      .join(' · ');

    return { title, text: fallbackText || title || 'Project note' };
  }

  return { title: null, text: stringifyValue(highlight) ?? 'Project note' };
};

const formattedHighlights = highlights.map(formatHighlight).filter((item) => item.text.trim().length > 0);
---

<BaseLayout title={`${title} | Crystonix`} description={description}>
  <article class="project-detail">
    <header class="page-header project-detail__header">
      <p class="eyebrow">{category} · {status}</p>
      <h1 class="page-title">{title}</h1>
      <p class="page-lead">{description}</p>

      {(links?.repo || links?.demo) && (
        <div class="actions">
          {links?.repo && (
            <a class="button button--primary" href={links.repo} rel="noreferrer">View repository</a>
          )}
          {links?.demo && (
            <a class="button button--secondary" href={links.demo} rel="noreferrer">Open demo</a>
          )}
        </div>
      )}
    </header>

    {mediaItems.length > 0 && (
      <section class="project-media" aria-label="Project media">
        {mediaItems.map((item) => (
          <figure class="project-media__item">
            {item.type === 'image' && (
              <img
                src={item.src}
                alt={item.alt ?? ''}
                loading="lazy"
                style={{ objectPosition: item.position ?? 'center' }}
              />
            )}

            {item.type === 'video' && (
              <video controls playsinline preload="metadata" poster={item.poster} style={{ objectPosition: item.position ?? 'center' }}>
                <source src={item.src} />
                Your browser does not support the video element.
              </video>
            )}

            {item.type === 'youtube' && (
              <div class="project-media__embed">
                <iframe
                  src={item.src}
                  title={item.title ?? title}
                  loading="lazy"
                  allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
                  allowfullscreen
                ></iframe>
              </div>
            )}

            {item.title && <figcaption>{item.title}</figcaption>}
          </figure>
        ))}
      </section>
    )}

    <div class="project-detail__layout">
      <div class="project-detail__content prose">
        <Content />
      </div>

      <aside class="project-detail__aside card" aria-label="Project summary">
        <h2>At a glance</h2>

        <div class="project-detail__meta-list">
          <div>
            <span>Area</span>
            <strong>{category}</strong>
          </div>
          <div>
            <span>Type</span>
            <strong>{status}</strong>
          </div>
        </div>

        {tags.length > 0 && (
          <div>
            <h3>Tools</h3>
            <div class="project-card__meta" aria-label="Project tags">
              {tags.map((tag) => <span class="badge">{tag}</span>)}
            </div>
          </div>
        )}

        {formattedHighlights.length > 0 && (
          <div>
            <h3>Notes</h3>
            <ul class="list">
              {formattedHighlights.map((item) => (
                <li>
                  {item.title && <strong>{item.title}: </strong>}
                  {item.text}
                </li>
              ))}
            </ul>
          </div>
        )}
      </aside>
    </div>
  </article>
</BaseLayout>
