---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const projects = await getCollection('projects');

  return projects.map((project) => ({
    params: { slug: project.id },
    props: { project },
  }));
}

const { project } = Astro.props;
const { Content } = await render(project);
const { title, description, category, status, tags, highlights, links } = project.data;

const formatHighlight = (highlight: unknown) => {
  if (typeof highlight === 'string') {
    return { title: null, text: highlight };
  }

  if (
    highlight &&
    typeof highlight === 'object' &&
    'text' in highlight &&
    typeof highlight.text === 'string'
  ) {
    return {
      title: 'title' in highlight && typeof highlight.title === 'string' ? highlight.title : null,
      text: highlight.text,
    };
  }

  return { title: null, text: String(highlight) };
};
---

<BaseLayout title={`${title} | Crystonix`} description={description}>
  <article class="project-detail">
    <header class="page-header project-detail__header">
      <p class="eyebrow">{category} · {status}</p>
      <h1 class="page-title">{title}</h1>
      <p class="page-lead">{description}</p>

      {(links?.repo || links?.demo) && (
        <div class="actions">
          {links?.repo && (
            <a class="button button--primary" href={links.repo} rel="noreferrer">View repository</a>
          )}
          {links?.demo && (
            <a class="button button--secondary" href={links.demo} rel="noreferrer">Open demo</a>
          )}
        </div>
      )}
    </header>

    <div class="project-detail__layout">
      <div class="project-detail__content prose">
        <Content />
      </div>

      <aside class="project-detail__aside card" aria-label="Project summary">
        <h2>At a glance</h2>

        <div class="project-detail__meta-list">
          <div>
            <span>Area</span>
            <strong>{category}</strong>
          </div>
          <div>
            <span>Type</span>
            <strong>{status}</strong>
          </div>
        </div>

        {tags.length > 0 && (
          <div>
            <h3>Tools</h3>
            <div class="project-card__meta" aria-label="Project tags">
              {tags.map((tag) => <span class="badge">{tag}</span>)}
            </div>
          </div>
        )}

        {highlights.length > 0 && (
          <div>
            <h3>Notes</h3>
            <ul class="list">
              {highlights.map((highlight) => {
                const item = formatHighlight(highlight);

                return (
                  <li>
                    {item.title && <strong>{item.title}: </strong>}
                    {item.text}
                  </li>
                );
              })}
            </ul>
          </div>
        )}
      </aside>
    </div>
  </article>
</BaseLayout>
