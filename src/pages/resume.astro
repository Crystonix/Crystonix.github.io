---
import BaseLayout from '../layouts/BaseLayout.astro';

const skillGroups = [
  {
    title: 'Web and content systems',
    description:
      'Portfolio pages, content workflows, deployment, and structured project presentation.',
    items: [
      'Astro',
      'TypeScript',
      'Directus',
      'PostgreSQL',
      'Redis',
      'GitHub Pages',
    ],
  },
  {
    title: 'Game and interactive systems',
    description:
      'Engine experiments, procedural layouts, plugin ideas, and visible rule-based prototypes.',
    items: ['Godot', 'GDScript', 'C++', 'GDExtension', 'Procedural generation'],
  },
  {
    title: 'Visual and browser graphics',
    description:
      '3D scenes, animated atmosphere, visual collections, and game-art presentation.',
    items: ['Three.js', 'WebGL', 'Vite', 'JavaScript', 'Particles', 'Game art'],
  },
];

const selectedWork = [
  {
    title: 'Artist Platform',
    href: '/projects/artist-platform/',
    label: 'Web project',
    description:
      'A foundation for artist pages, galleries, content editing, and structured publishing workflows.',
  },
  {
    title: 'Godot Dungeon Generation',
    href: '/projects/godot-dungeon-generation/',
    label: 'Game system',
    description:
      'A procedural generation project that builds cave-like layouts from grid data and repeated rule passes.',
  },
  {
    title: 'Underwater Scene',
    href: '/projects/underwater-threejs-scene/',
    label: '3D scene',
    description:
      'A browser-based scene focused on terrain, lighting, camera movement, animated bubbles, and atmosphere.',
  },
  {
    title: 'Game Art & Visuals',
    href: '/projects/game-art-visuals/',
    label: 'Visual work',
    description:
      'A visual collection for character presentation, scene composition, motion work, GIFs, and renders.',
  },
];

const bestFit = [
  'Projects where interface work, visuals, and implementation need to support the same idea.',
  'Creative tools, games, interactive scenes, or visual portfolio work that should feel clear and alive.',
  'Work where a small prototype can become easier to use, explain, and keep building on.',
];
---

<BaseLayout
  title="Resume | Crystonix"
  description="Project-backed resume page for the Crystonix portfolio."
>
  <header class="page-header">
    <p class="eyebrow">Resume</p>
    <h1 class="page-title">A project-backed summary.</h1>
    <p class="page-lead">
      A concise view of the tools, systems, and visual work already represented
      in this portfolio.
    </p>
  </header>

  <section class="section split" aria-labelledby="resume-profile-title">
    <div>
      <p class="section__label">Profile</p>
      <h2 id="resume-profile-title" class="section__title">
        Building across web, games, and visual media.
      </h2>
    </div>
    <div class="prose">
      <p>
        My work here sits between structure and visible output. Some projects
        are web foundations with content workflows. Others are game-system
        experiments, browser graphics, or visual collections.
      </p>
      <p>
        I learn best when there is something on screen to react to: a page, a
        layout, a rule system, a scene, or a piece of visual work that can be
        improved through iteration.
      </p>
    </div>
  </section>

  <section class="section" aria-labelledby="resume-skills-title">
    <div class="section__header">
      <p class="section__label">Tools</p>
      <h2 id="resume-skills-title" class="section__title">
        Tools and areas shown by the projects.
      </h2>
      <p class="section__description">
        Grouped by where they appear in the portfolio, so the list reads as
        evidence instead of a detached checklist.
      </p>
    </div>
    <div class="card-grid">
      {
        skillGroups.map((group) => (
          <article class="card skill-card">
            <h3>{group.title}</h3>
            <p>{group.description}</p>
            <ul class="tool-list" aria-label={`${group.title} tools`}>
              {group.items.map((item) => (
                <li>{item}</li>
              ))}
            </ul>
          </article>
        ))
      }
    </div>
  </section>

  <section class="section" aria-labelledby="resume-work-title">
    <div class="section__header">
      <p class="section__label">Selected work</p>
      <h2 id="resume-work-title" class="section__title">Project evidence.</h2>
      <p class="section__description">
        Each entry links to a project page with more context, media, tools, and
        notes.
      </p>
    </div>
    <div class="card-grid">
      {
        selectedWork.map((project) => (
          <a class="card" href={project.href}>
            <span class="badge">{project.label}</span>
            <h3>{project.title}</h3>
            <p>{project.description}</p>
          </a>
        ))
      }
    </div>
  </section>

  <section class="section split" aria-labelledby="resume-fit-title">
    <div>
      <p class="section__label">Best fit</p>
      <h2 id="resume-fit-title" class="section__title">
        Projects where the result needs to feel clear and alive.
      </h2>
    </div>
    <div class="stack">
      <p class="section__description">
        I am most interested in work where the technical part is not separate
        from what someone sees or uses. The best fit is a project where the
        interface, system, and visual direction can improve together.
      </p>
      <ul class="list">
        {bestFit.map((item) => <li>{item}</li>)}
      </ul>
      <div class="actions" aria-label="Resume links">
        <a class="button button--secondary" href="/projects/">Projects</a>
        <a class="button button--secondary" href="/about/">About</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .skill-card {
    display: grid;
    align-content: start;
    gap: 0.95rem;
  }

  .tool-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .tool-list li {
    border: 1px solid var(--color-border);
    border-radius: 999px;
    background: rgba(125, 211, 252, 0.08);
    color: var(--color-accent);
    font-size: 0.82rem;
    font-weight: 700;
    line-height: 1.2;
    padding: 0.35rem 0.65rem;
  }
</style>
