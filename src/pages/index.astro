---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import ProjectCard from '../components/ProjectCard.astro';
import SectionHeading from '../components/SectionHeading.astro';

const projects = await getCollection('projects');
const featuredProjects = projects
  .filter((project) => project.data.featured)
  .sort((a, b) => a.data.order - b.data.order);
const visualProjects = projects
  .filter((project) => project.data.category === 'Visual Work')
  .sort((a, b) => a.data.order - b.data.order);

const heroProjectIds = [
  'game-art-visuals',
  'underwater-threejs-scene',
  'godot-dungeon-generation',
  'animation-legal-trap',
];
const heroReelItems = [];

for (const id of heroProjectIds) {
  const project = projects.find((entry) => entry.id === id);
  const cover = project?.data.heroCover ?? project?.data.cover;

  if (project && cover) {
    heroReelItems.push({
      title: project.data.title,
      label: project.data.category,
      href: `/projects/${project.id}/`,
      cover,
    });
  }
}

const focusAreas = [
  {
    title: 'Web Projects',
    description: 'Interfaces, tools, and small platforms built for the browser.',
  },
  {
    title: 'Game Systems',
    description: 'Godot projects, procedural generation, plugins, and gameplay tools.',
  },
  {
    title: 'Visual Work',
    description: 'Game art, animation, 3D scenes, and motion experiments.',
  },
];
---

<BaseLayout
  title="Crystonix | Portfolio"
  description="Portfolio of projects, experiments, games, and visual work by Crystonix."
>
  <Hero
    eyebrow="Projects · Experiments · Visuals"
    title="Crystonix"
    lead="Projects, experiments, and visual work I’ve made while exploring web development, games, and interactive media."
    reelItems={heroReelItems}
  />

  <section class="section" aria-labelledby="featured-projects-title">
    <SectionHeading
      label="Featured work"
      title="Things I’ve made and explored."
      description="A mix of web projects, game systems, interactive scenes, and visual pieces."
    />

    <div class="card-grid">
      {featuredProjects.map((project) => (
        <ProjectCard
          title={project.data.title}
          description={project.data.description}
          href={`/projects/${project.id}/`}
          tags={project.data.tags}
          category={project.data.category}
          status={project.data.status}
          cover={project.data.cover}
        />
      ))}
    </div>
  </section>

  <section class="section split" aria-labelledby="focus-title">
    <div>
      <p class="section__label">What I work on</p>
      <h2 id="focus-title" class="section__title">I like building things that mix structure with visuals.</h2>
    </div>

    <div class="stack">
      <p class="section__description">
        Some projects are practical web apps, some are Godot tools or prototypes, and some are visual scenes or animation work. This site collects the pieces I want to show, improve, and keep building on.
      </p>
      <div class="focus-list">
        {focusAreas.map((area) => (
          <article class="focus-item">
            <h3>{area.title}</h3>
            <p>{area.description}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section" aria-labelledby="visual-work-title">
    <SectionHeading
      label="Visual work"
      title="Game art, animation, and scenes."
      description="Visual pieces get their own space here, from game-art presentation to Blender animation and browser-based 3D scenes."
    />

    <div class="card-grid">
      {visualProjects.map((project) => (
        <ProjectCard
          title={project.data.title}
          description={project.data.description}
          href={`/projects/${project.id}/`}
          tags={project.data.tags}
          category={project.data.category}
          status={project.data.status}
          cover={project.data.cover}
        />
      ))}
    </div>
  </section>

  <section class="section card" aria-labelledby="explore-title">
    <p class="section__label">Explore</p>
    <h2 id="explore-title" class="section__title">See the full project list.</h2>
    <p class="section__description">
      Browse the full project list or visit GitHub for more experiments, older repositories, and work in progress.
    </p>
    <div class="actions">
      <a class="button button--primary" href="/projects/">Open all projects</a>
      <a class="button button--secondary" href="https://github.com/Crystonix" rel="noreferrer">View GitHub profile</a>
    </div>
  </section>
</BaseLayout>
