---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import ProjectCard from '../components/ProjectCard.astro';
import SectionHeading from '../components/SectionHeading.astro';

const projects = await getCollection('projects');
const featuredProjects = projects
  .filter((project) => project.data.featured)
  .sort((a, b) => a.data.order - b.data.order);

const focusAreas = [
  {
    title: 'Web application architecture',
    description:
      'Static-first Astro work, service boundaries, authentication flows, and content-backed product foundations.',
  },
  {
    title: 'Game systems and tooling',
    description:
      'Godot systems, procedural generation, editor tooling, and performance-oriented implementation paths.',
  },
  {
    title: 'Graphics and creative tech',
    description:
      'Three.js scenes, Blender production work, animation, particles, and browser-based visual experiments.',
  },
];
---

<BaseLayout
  title="Crystonix | Software, game systems, and creative tech"
  description="Crystonix portfolio featuring web applications, game development systems, graphics experiments, and technical case studies."
>
  <Hero
    eyebrow="Software · Game systems · Creative tech"
    title="Crystonix"
    lead="A project portfolio focused on durable web architecture, Godot systems, procedural generation, and browser-based graphics work."
  />

  <section class="section" aria-labelledby="featured-projects-title">
    <SectionHeading
      label="Featured work"
      title="Selected projects with real technical substance."
      description="These projects were selected from the repository audit because they have the strongest architecture, implementation, or visual-systems story."
    />

    <div class="card-grid">
      {featuredProjects.map((project) => (
        <ProjectCard
          title={project.data.title}
          description={project.data.description}
          href={`/projects/${project.id}/`}
          tags={project.data.tags}
          category={project.data.category}
          status={project.data.status}
        />
      ))}
    </div>
  </section>

  <section class="section split" aria-labelledby="focus-title">
    <div>
      <p class="section__label">Focus</p>
      <h2 id="focus-title" class="section__title">A portfolio organized by engineering signal.</h2>
    </div>

    <div class="stack">
      <p class="section__description">
        The site is now content-driven: projects live as typed Markdown entries, the homepage only shows selected featured work, and the full project index can grow without duplicating page logic.
      </p>
      <div class="focus-list">
        {focusAreas.map((area) => (
          <article class="focus-item">
            <h3>{area.title}</h3>
            <p>{area.description}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section card" aria-labelledby="next-title">
    <p class="section__label">Next</p>
    <h2 id="next-title" class="section__title">Turn the strongest projects into deeper case studies.</h2>
    <p class="section__description">
      The structure is ready for screenshots, architecture diagrams, performance notes, and more precise implementation details as each repository is cleaned up.
    </p>
    <div class="actions">
      <a class="button button--primary" href="/projects/">Open all projects</a>
      <a class="button button--secondary" href="https://github.com/Crystonix" rel="noreferrer">View GitHub profile</a>
    </div>
  </section>
</BaseLayout>
