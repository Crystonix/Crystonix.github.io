---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import ProjectCard from '../components/ProjectCard.astro';
import SectionHeading from '../components/SectionHeading.astro';

const projects = await getCollection('projects');
const featuredProjects = projects
  .filter((project) => project.data.featured)
  .sort((a, b) => a.data.order - b.data.order);
const visualProjects = projects
  .filter((project) => project.data.category === 'Visual work')
  .sort((a, b) => a.data.order - b.data.order);

const focusAreas = [
  {
    title: 'Web products',
    description:
      'Portfolio platforms, login flows, content workflows, and small product foundations built for real use cases.',
  },
  {
    title: 'Game systems',
    description:
      'Godot projects, procedural generation, reusable tools, and gameplay-facing prototypes.',
  },
  {
    title: 'Visual work',
    description:
      'Game art, Blender animation, browser-based 3D scenes, atmosphere, motion, and presentation work.',
  },
];
---

<BaseLayout
  title="Crystonix | Web, game, and visual work"
  description="Portfolio of Crystonix: web products, Godot systems, procedural generation, game art, animation, and browser-based visual work."
>
  <Hero
    eyebrow="Web · Games · Visuals"
    title="Crystonix"
    lead="Selected work across web products, Godot systems, procedural generation, game art, animation, and browser-based 3D scenes."
  />

  <section class="section" aria-labelledby="featured-projects-title">
    <SectionHeading
      label="Featured work"
      title="Projects selected for presentation, craft, and direction."
      description="A concise selection of work that shows product thinking, game-system experiments, and visual production."
    />

    <div class="card-grid">
      {featuredProjects.map((project) => (
        <ProjectCard
          title={project.data.title}
          description={project.data.description}
          href={`/projects/${project.id}/`}
          tags={project.data.tags}
          category={project.data.category}
          status={project.data.status}
        />
      ))}
    </div>
  </section>

  <section class="section split" aria-labelledby="focus-title">
    <div>
      <p class="section__label">Direction</p>
      <h2 id="focus-title" class="section__title">A portfolio for web, games, and visual work.</h2>
    </div>

    <div class="stack">
      <p class="section__description">
        The portfolio is intentionally split into three visible areas: web products, game systems, and visual work. That keeps the creative pieces visible instead of reducing everything to code and tooling.
      </p>
      <div class="focus-list">
        {focusAreas.map((area) => (
          <article class="focus-item">
            <h3>{area.title}</h3>
            <p>{area.description}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section" aria-labelledby="visual-work-title">
    <SectionHeading
      label="Visual work"
      title="Game art, animation, and browser-based scenes."
      description="This section gives the visual side of the portfolio its own space: game-art presentation, Blender animation, and interactive 3D atmosphere."
    />

    <div class="card-grid">
      {visualProjects.map((project) => (
        <ProjectCard
          title={project.data.title}
          description={project.data.description}
          href={`/projects/${project.id}/`}
          tags={project.data.tags}
          category={project.data.category}
          status={project.data.status}
        />
      ))}
    </div>
  </section>

  <section class="section card" aria-labelledby="explore-title">
    <p class="section__label">Explore</p>
    <h2 id="explore-title" class="section__title">Browse the full project selection.</h2>
    <p class="section__description">
      The full index includes featured pieces, supporting prototypes, reusable Godot tooling, and visual projects that can be expanded with screenshots, GIFs, renders, and process breakdowns.
    </p>
    <div class="actions">
      <a class="button button--primary" href="/projects/">Open all projects</a>
      <a class="button button--secondary" href="https://github.com/Crystonix" rel="noreferrer">View GitHub profile</a>
    </div>
  </section>
</BaseLayout>
