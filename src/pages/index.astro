---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import ProjectCard from '../components/ProjectCard.astro';
import SectionHeading from '../components/SectionHeading.astro';
import { focusAreas, heroProjectIds, homeHero } from '../data/home';
import {
  getFeaturedProjects,
  getHeroReelItems,
  sortProjects,
} from '../lib/projectQueries';

const projects = sortProjects(await getCollection('projects'));
const featuredProjects = getFeaturedProjects(projects);
const heroReelItems = getHeroReelItems(projects, heroProjectIds);
---

<BaseLayout
  title="Crystonix | Portfolio"
  description="Portfolio of projects, experiments, games, and visual work by Crystonix."
>
  <Hero
    eyebrow={homeHero.eyebrow}
    title={homeHero.title}
    lead={homeHero.lead}
    reelItems={heroReelItems}
  />

  <section class="section" aria-labelledby="featured-projects-title">
    <SectionHeading
      label="Featured work"
      title="Things I’ve made and explored."
      description="A mix of web projects, game systems, interactive scenes, and visual pieces."
    />

    <div class="card-grid">
      {
        featuredProjects.map((project) => (
          <ProjectCard
            title={project.data.title}
            description={project.data.description}
            href={`/projects/${project.id}/`}
            tags={project.data.tags}
            category={project.data.category}
            status={project.data.status}
            cover={project.data.cover}
          />
        ))
      }
    </div>
  </section>

  <section class="section split" aria-labelledby="focus-title">
    <div>
      <p class="section__label">What I work on</p>
      <h2 id="focus-title" class="section__title">
        I like building things that mix structure with visuals.
      </h2>
    </div>

    <div class="stack">
      <p class="section__description">
        Some projects are practical web apps, some are Godot tools or
        prototypes, and some are visual scenes or animation work. This site
        collects the pieces I want to show, improve, and keep building on.
      </p>
      <div class="focus-list">
        {
          focusAreas.map((area) => (
            <article class="focus-item">
              <h3>{area.title}</h3>
              <p>{area.description}</p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section class="section card" aria-labelledby="explore-title">
    <p class="section__label">Explore</p>
    <h2 id="explore-title" class="section__title">
      See the full project list.
    </h2>
    <p class="section__description">
      Browse the full project list or visit GitHub for more experiments, older
      repositories, and work in progress.
    </p>
    <div class="actions">
      <a class="button button--primary" href="/projects/">Open all projects</a>
      <a
        class="button button--secondary"
        href="https://github.com/Crystonix"
        rel="noreferrer">View GitHub profile</a
      >
    </div>
  </section>
</BaseLayout>
