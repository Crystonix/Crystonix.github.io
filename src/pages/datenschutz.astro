---
import BaseLayout from '../layouts/BaseLayout.astro';
import { legalProfile } from '../data/legal';
---

<BaseLayout
  title="Datenschutz | Crystonix"
  description="Datenschutzhinweise für das Crystonix Portfolio."
  lang="de"
>
  <header class="page-header legal-header">
    <p class="eyebrow">Datenschutz</p>
    <h1 class="page-title">Datenschutzhinweise.</h1>
    <p class="page-lead">
      Informationen dazu, welche Daten beim Besuch dieser statischen
      Portfolio-Website verarbeitet werden können.
    </p>
  </header>

  <section class="section legal-page" aria-label="Datenschutzhinweise">
    <article class="card legal-card">
      <p class="section__label">Verantwortlicher</p>
      <h2 class="section__title">{legalProfile.ownerName}</h2>
      <address class="legal-address">
        {legalProfile.address.map((line) => <span>{line}</span>)}
      </address>
      <p>
        E-Mail: <a href={`mailto:${legalProfile.email}`}>{legalProfile.email}</a>
      </p>
    </article>

    <article class="card legal-card">
      <p class="section__label">Hosting und Zugriffsdaten</p>
      <p>
        Diese Website wird als statische Website über {legalProfile.hostingProvider}
        bereitgestellt. Beim Aufruf der Website können durch den Hosting-Anbieter
        technische Zugriffsdaten verarbeitet werden, etwa IP-Adresse, Datum und
        Uhrzeit des Aufrufs, angeforderte Datei, Browser-Informationen und
        Referrer.
      </p>
      <p>
        Die Verarbeitung dient der sicheren und stabilen Bereitstellung der
        Website. Rechtsgrundlage ist Art. 6 Abs. 1 lit. f DSGVO.
      </p>
      <p>
        Weitere Informationen stellt GitHub in seiner Datenschutzerklärung bereit:
        <a href={legalProfile.hostingPrivacyUrl} rel="noreferrer">
          GitHub Privacy Statement
        </a>.
      </p>
    </article>

    <article class="card legal-card">
      <p class="section__label">Keine eigenen Analyse- oder Trackingdienste</p>
      <p>
        Diese Website verwendet nach aktuellem Stand keine eigenen Analysewerkzeuge,
        keine Newsletter-Anmeldung, kein Kontaktformular und keine externen
        Webfonts. Die Website setzt selbst keine Cookies.
      </p>
    </article>

    <article class="card legal-card">
      <p class="section__label">Externe Links</p>
      <p>
        Diese Website enthält Links zu externen Angeboten, insbesondere zu GitHub.
        Beim Öffnen externer Links gelten die Datenschutzinformationen des
        jeweiligen Anbieters.
      </p>
    </article>

    <article class="card legal-card">
      <p class="section__label">Rechte betroffener Personen</p>
      <p>
        Betroffene Personen haben im Rahmen der gesetzlichen Voraussetzungen Rechte
        auf Auskunft, Berichtigung, Löschung, Einschränkung der Verarbeitung,
        Datenübertragbarkeit und Widerspruch.
      </p>
      <p>
        Außerdem besteht das Recht, sich bei einer Datenschutzaufsichtsbehörde zu
        beschweren.
      </p>
    </article>

    <p class="legal-updated">Stand: {legalProfile.lastUpdated}</p>
  </section>
</BaseLayout>

<style>
  .legal-header .page-title {
    max-width: 12ch;
  }

  .legal-page {
    display: grid;
    gap: 1rem;
    max-width: 860px;
  }

  .legal-card {
    display: grid;
    gap: 0.85rem;
  }

  .legal-card p,
  .legal-address,
  .legal-updated {
    margin: 0;
    color: var(--color-muted);
    font-style: normal;
  }

  .legal-address {
    display: grid;
    gap: 0.15rem;
  }

  .legal-card a {
    color: var(--color-accent);
    text-decoration: underline;
    text-underline-offset: 0.2em;
  }
</style>
